function showRoleReminder(sc,casoIdx,phase){
  var roles=getRoleForCaso(casoIdx);
  var msgs={
    'decision':'<strong style="color:var(--accent);">'+esc(roles.esceptico)+'</strong> (Escéptico): argumenta contra la opción más obvia antes de decidir.',
    'justification':'<strong style="color:var(--accent);">'+esc(roles.portavoz)+'</strong> (Portavoz): escribe la justificación del grupo.'
  };
  if(!msgs[phase])return;
  var rem=mkEl('div');
  rem.style.cssText='background:rgba(255,184,48,.07);border:1px solid rgba(255,184,48,.2);border-radius:var(--r);padding:10px 14px;margin-bottom:12px;font-size:12px;color:var(--text2);line-height:1.6;display:flex;gap:8px;align-items:flex-start;';
  rem.innerHTML='<i class="ti ti-user-check" style="color:var(--amber);font-size:16px;flex-shrink:0;margin-top:1px;"></i><div>'+msgs[phase]+'</div>';
  sc.appendChild(rem);
}

// ══ PIN ══
var pbuf='';
function openPin(){pbuf='';updPin();gi('perr').textContent='';gi('pinov').style.display='flex';}
function closePin(){gi('pinov').style.display='none';gi('tab-g').classList.add('active');gi('tab-d').classList.remove('active');}
function pk(k){
  gi('perr').textContent='';
  if(k==='del')pbuf=pbuf.slice(0,-1);
  else if(k==='ok'){chkPin();return;}
  else if(pbuf.length<4)pbuf+=k;
  updPin();
  if(pbuf.length===4)setTimeout(chkPin,150);
}
function updPin(){for(var i=0;i<4;i++)gi('pd'+i).classList.toggle('on',i<pbuf.length);}
function chkPin(){
  if(pbuf===PIN){gi('pinov').style.display='none';setMode('d');}
  else{
    gi('perr').textContent='// PIN incorrecto';pbuf='';updPin();
    var b=document.querySelector('.pinbox');
    var vs=['-10px','10px','-6px','6px','0'];
    vs.forEach(function(v,i){setTimeout(function(){b.style.transform='translateX('+v+')';},i*70);});
    vib([100,50,100]);
  }
}

// MODE
function setMode(m){
  gi('tab-g').classList.toggle('active',m==='g');
  gi('tab-d').classList.toggle('active',m==='d');
  gi('panel-g').style.display=m==='g'?'block':'none';
  gi('panel-d').style.display=m==='d'?'block':'none';
  if(m==='d'){renderRank();renderJust();}
}

// STORAGE
function getSt(){try{return JSON.parse(localStorage.getItem('qtr_v5')||'[]');}catch(e){return[];}}
