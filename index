function countdown(cb){
  var ov=gi('cdov'),nm=gi('cdn'),lb=gi('cdl');
  ov.style.display='flex';
  var n=3,msgs=['PREPARANDO...','ATENTOS...','¡AHORA!'];
  nm.textContent=n;lb.textContent=msgs[0];vib(80);
  var iv=setInterval(function(){
    n--;
    if(n<=0){clearInterval(iv);ov.style.display='none';cb();return;}
    nm.style.animation='none';
    requestAnimationFrame(function(){requestAnimationFrame(function(){nm.style.animation='pop .4s ease';});});
    nm.textContent=n;lb.textContent=msgs[3-n]||'';vib(50);
  },900);
}

function loadCaso(){
