function renderRank(){
  var data=getSt().sort(function(a,b){return b.total-a.total;});
  var el=gi('rank-live');var m=['🥇','🥈','🥉'];
  if(!data.length){el.innerHTML='<div style="font-size:12px;color:var(--text3);font-family:var(--mono);">// esperando grupos...</div>';return;}
  var h='';
  data.forEach(function(g,i){
    h+='<div class="rrow"><span class="rpos">'+(m[i]||(i+1))+'</span><span class="rname">'+esc(g.name)+'</span><span class="rpts">'+g.total+' pts</span></div>';
  });
  el.innerHTML=h;
}

function renderJust(){
  var data=getJust();
  var el=gi('just-panel');
  if(!data.length){el.innerHTML='<div style="font-size:12px;color:var(--text3);font-family:var(--mono);">// sin justificaciones aún...</div>';return;}
  var h='';
  data.forEach(function(j){
    h+='<div style="margin-bottom:14px;">';
    h+='<div style="font-family:var(--mono);font-size:10px;color:var(--accent);margin-bottom:4px;letter-spacing:.06em;">'+esc(j.grp)+' · CASO '+j.caso+'</div>';
    h+='<div class="just-disp">'+esc(j.texto)+'</div>';
