function mkEl(tag,opts){
  var el=document.createElement(tag);
  if(opts){
    if(opts.cls)el.className=opts.cls;
    if(opts.txt)el.textContent=opts.txt;
    if(opts.html)el.innerHTML=opts.html;
    if(opts.id)el.id=opts.id;
    if(opts.style)el.style.cssText=opts.style;
  }
  return el;
}

function buildComplexity(parent,c){
  var cx=c.complexity;
  var labels=['','BAJA COMPLEJIDAD','COMPLEJIDAD MEDIA','ALTA COMPLEJIDAD'];
  var tags=['','cx-tag-1','cx-tag-2','cx-tag-3'];
  var fills=['','cx-1','cx-2','cx-3'];
  var wrap=mkEl('div',{cls:'complexity'});
  var lbl=mkEl('div',{cls:'complexity-lbl'});
  var ls=mkEl('span',{txt:'COMPLEJIDAD DEL CASO'});
  var tag=mkEl('span',{cls:'cx-tag '+tags[cx],txt:labels[cx]});
  lbl.appendChild(ls);lbl.appendChild(tag);
  var track=mkEl('div',{cls:'complexity-track'});
  var fill=mkEl('div',{cls:'complexity-fill '+fills[cx]});
  track.appendChild(fill);wrap.appendChild(lbl);wrap.appendChild(track);
  parent.appendChild(wrap);
}

function buildCaso(sc,c){
  // caso card
  var card=mkEl('div',{cls:'ccard fade'});
  card.appendChild(mkEl('div',{cls:'cnum',txt:'CASO '+c.id+' · DIAGNÓSTICO DIFERENCIAL'}));
  card.appendChild(mkEl('div',{cls:'ctit',txt:c.titulo}));
  var datos=c.datos||[];
  datos.forEach(function(d){
    var row=mkEl('div',{cls:'dato'});
    var ic=mkEl('i',{cls:'ti '+d.i});
    var sp=mkEl('span',{txt:d.t});
    row.appendChild(ic);row.appendChild(sp);card.appendChild(row);
  });
  sc.appendChild(card);

  // complexity
  buildComplexity(sc,c);

  // reveal sections
  if(c.mechanic==='reveal'){
    c.datos_reveal.forEach(function(sec,si){
      var rc=mkEl('div',{cls:'revcard'});
      var rh=mkEl('div',{cls:'revhdr'});
      (function(si2){rh.onclick=function(){
        var bd=gi('rb-'+si2),bg=gi('rbg-'+si2);
        var op=bd.classList.toggle('open');
        bg.textContent=op?'REVELADO':'TAP PARA REVELAR';
        bg.className='clue'+(op?' revealed':'');
        if(op)vib(30);
      };})(si);
      rh.appendChild(mkEl('span',{cls:'revhdr-lbl',txt:sec.label}));
      var bg=mkEl('span',{cls:'clue'+(si===0?' revealed':''),id:'rbg-'+si,txt:si===0?'VISIBLE':'TAP PARA REVELAR'});
      rh.appendChild(bg);rc.appendChild(rh);
      var bd=mkEl('div',{cls:'revbody'+(si===0?' open':''),id:'rb-'+si});
      sec.datos.forEach(function(d){
        var row=mkEl('div',{cls:'dato'});
        row.appendChild(mkEl('i',{cls:'ti '+d.i}));
        row.appendChild(mkEl('span',{txt:d.t}));
        bd.appendChild(row);
      });
      rc.appendChild(bd);sc.appendChild(rc);
    });
  }

  // mech tag
  sc.appendChild(mkEl('div',{cls:'mech-tag',txt:c.mechLabel}));

  if(c.mechanic==='order'){
    buildOrder(sc,c);
  } else {
    var btn=mkEl('button',{cls:'btn btn-p',html:'<i class="ti ti-message-circle-2"></i> Ver opiniones de los médicos'});
    btn.onclick=function(){btn.remove();buildNPCs(sc,c);};
    sc.appendChild(btn);
  }
}

function buildOrder(sc,c){
  var keys=[];for(var k=0;k<c.steps.length;k++)keys.push(k);
  keys.sort(function(){return Math.random()-.5;});
  var ol=mkEl('div',{id:'olist'});
  keys.forEach(function(idx){
    var item=mkEl('div',{cls:'oitem',id:'oi-'+idx});
    (function(i2){item.onclick=function(){selOrder(i2,c);};})(idx);
    item.appendChild(mkEl('div',{cls:'onum',id:'on-'+idx,txt:'—'}));
    item.appendChild(mkEl('div',{cls:'otxt',txt:c.steps[idx]}));
    ol.appendChild(item);
  });
  sc.appendChild(ol);
  var btn=mkEl('button',{cls:'btn btn-p',id:'btn-co',html:'<i class="ti ti-check"></i> Confirmar orden'});
  btn.disabled=true;btn.style.marginTop='10px';
  btn.onclick=function(){
    if(S_ROLES.esceptico)showRoleReminder(sc,S.ci,'decision');
    buildJustification(sc,c,'order');
  };
  sc.appendChild(btn);
}

function selOrder(idx,c){
  var pos=S.order.indexOf(idx);
  if(pos>=0){S.order.splice(pos,1);gi('oi-'+idx).classList.remove('osel');}
  else if(S.order.length<c.steps.length){S.order.push(idx);gi('oi-'+idx).classList.add('osel');}
  c.steps.forEach(function(_,i){
    var p=S.order.indexOf(i);
    gi('on-'+i).textContent=p>=0?(p+1):'—';
  });
  gi('btn-co').disabled=(S.order.length!==c.steps.length);
  vib(20);
}

function buildNPCs(sc,c){
  if(S_ROLES.esceptico)showRoleReminder(sc,S.ci,'decision');
  sc.appendChild(mkEl('div',{cls:'sec',txt:'¿Quién tiene el diagnóstico correcto?'}));
  c.npcs.forEach(function(npc,i){
    var nc=mkEl('div',{cls:'npc fade',id:'npc-'+i});
    nc.style.animationDelay=(i*0.08)+'s';
    (function(i2){nc.onclick=function(){selNPC(i2,c);};})(i);
    nc.appendChild(mkEl('div',{cls:'npersona',txt:npc.persona}));
    var hdr=mkEl('div',{cls:'npch'});
    var av=mkEl('div',{cls:'av'});
    av.style.background=npc.bg;
    var avi=mkEl('i',{cls:'ti '+npc.icon});avi.style.color=npc.tc;av.appendChild(avi);
    var info=mkEl('div');
    info.appendChild(mkEl('div',{cls:'nname',txt:npc.n}));
    info.appendChild(mkEl('div',{cls:'nrole',txt:npc.r}));
    hdr.appendChild(av);hdr.appendChild(info);
    nc.appendChild(hdr);
    nc.appendChild(mkEl('div',{cls:'ndiag',txt:npc.d}));
    nc.appendChild(mkEl('div',{cls:'narg',txt:npc.a}));
    sc.appendChild(nc);
  });
  var btn=mkEl('button',{cls:'btn btn-p',id:'btn-cn',html:'<i class="ti ti-check"></i> Confirmar respuesta del grupo'});
  btn.disabled=true;
  btn.onclick=function(){buildJustification(sc,c,'npc');};
  sc.appendChild(btn);
}

function selNPC(i,c){
  S.selNPC=i;
  document.querySelectorAll('.npc').forEach(function(el,j){el.classList.toggle('sel',j===i);});
  gi('btn-cn').disabled=false;vib(20);
}

// JUSTIFICATION
function buildJustification(sc,c,mechanic){
  clearInterval(S.tiv);
  // disable confirm buttons
  var bcn=gi('btn-cn'),bco=gi('btn-co');
  if(bcn)bcn.disabled=true;if(bco)bco.disabled=true;

  var wrap=mkEl('div',{cls:'just-wrap fade'});
  var lbl=mkEl('div',{cls:'just-label',html:'<i class="ti ti-brain"></i> ANTES DE REVELAR — JUSTIFICA'});
  var sub=mkEl('div',{cls:'just-sub'});
  var _r=getRoleForCaso(S.ci);
  var portavozName=_r.portavoz?(' <strong style="color:var(--accent);">'+esc(_r.portavoz)+'</strong> (Portavoz):'):'';
  sub.innerHTML=(portavozName||'')+" ¿Por qué eligieron esa respuesta? Escriban el razonamiento clínico clave en 1-2 líneas. El docente lo verá en tiempo real.";
  var ta=mkEl('textarea',{cls:'just-ta',id:'just-ta'});
  ta.placeholder='Ej: El dato más importante fue... porque...';
  ta.rows=3;
  wrap.appendChild(lbl);wrap.appendChild(sub);wrap.appendChild(ta);
  var btn=mkEl('button',{cls:'btn btn-p',html:'<i class="ti ti-send"></i> Enviar y ver resultado'});
  btn.style.marginTop='10px';
  btn.onclick=function(){
    var txt=gi('just-ta').value.trim();
    if(!txt){gi('just-ta').focus();gi('just-ta').style.borderColor='var(--red)';return;}
    saveJustification(S.ci+1,txt);
    if(mechanic==='npc')confirmNPC(c);
    else confirmOrder(c);
  };
  wrap.appendChild(btn);
  sc.appendChild(wrap);
  sc.scrollTop=sc.scrollHeight;
  ta.focus();
}

function saveJustification(casoNum,texto){
  var data=getJust();
  data.push({grp:S.grp,caso:casoNum,texto:texto,ts:new Date().toLocaleTimeString()});
  setJust(data);
}

function confirmOrder(c){
  var elapsed=Math.round((Date.now()-S.tstart)/1000);
  var ok=JSON.stringify(S.order)===JSON.stringify(c.steps_correct);
  var base=ok?100:0;
  var bonus=ok?Math.max(0,Math.round((45-Math.min(elapsed,45))/45*17)):0;
  S.scores.push({titulo:c.titulo,ok:ok,pts:base+bonus});
  showResult(c,ok,base+bonus,bonus);
  vib(ok?[100,50,200]:[200]);
}

function confirmNPC(c){
  var elapsed=Math.round((Date.now()-S.tstart)/1000);
  var npc=c.npcs[S.selNPC];
  var ok=npc.ok;
  var base=ok?100:0;
  var bonus=ok?Math.max(0,Math.round((45-Math.min(elapsed,45))/45*17)):0;
  S.scores.push({titulo:c.titulo,ok:ok,pts:base+bonus});
  showResult(c,ok,base+bonus,bonus);
  vib(ok?[100,50,200]:[200]);
}

function buildErrorFeedback(sc,c,mechanic){
  var errorType='';var errorDetail='';
  var labels={'omision':'ERROR DE OMISIÓN','frecuencia':'ERROR DE FRECUENCIA','anclaje':'ERROR DE ANCLAJE','extrapolacion':'ERROR DE EXTRAPOLACIÓN'};
  var cssMap={'omision':'errtype-omision','frecuencia':'errtype-frecuencia','anclaje':'errtype-anclaje','extrapolacion':'errtype-extrapolacion'};
  var icons={'omision':'ti-eye-off','frecuencia':'ti-trending-up','anclaje':'ti-anchor','extrapolacion':'ti-arrows-transfer-down'};
  var descriptions={'omision':'Había un dato clave disponible que el grupo no integró en su razonamiento.','frecuencia':'El grupo eligió el diagnóstico más común sin verificar si el contexto clínico lo respaldaba.','anclaje':'El grupo se fijó en un síntoma prominente y dejó de procesar el resto de la información.','extrapolacion':'El grupo aplicó criterios de otro escenario clínico sin adaptarlos al contexto actual.'};

  if(mechanic==='npc'&&S.selNPC!==null){
    var npc=c.npcs[S.selNPC];
    if(npc&&!npc.ok&&npc.errorType){errorType=npc.errorType;errorDetail=npc.errorDetail;}
  } else if(mechanic==='order'&&c.orderErrorType){
    errorType=c.orderErrorType;errorDetail=c.orderErrorDetail;
  }
  if(!errorType)return;

  var box=mkEl('div',{cls:'errbox fade'});
  var top=mkEl('div',{cls:'errtype'});
  var badge=mkEl('span',{cls:'errtype-badge '+(cssMap[errorType]||''),txt:labels[errorType]||errorType.toUpperCase()});
  top.appendChild(badge);
  box.appendChild(top);

  var iconRow=mkEl('div');iconRow.style.cssText='display:flex;gap:10px;align-items:flex-start;margin-bottom:10px;';
  var ic=mkEl('i',{cls:'ti '+(icons[errorType]||'ti-alert-circle')});ic.style.cssText='font-size:18px;color:var(--red);flex-shrink:0;margin-top:2px;';
  var typDesc=mkEl('div',{txt:descriptions[errorType]||''});typDesc.style.cssText='font-size:12px;color:var(--text3);line-height:1.6;font-style:italic;';
  iconRow.appendChild(ic);iconRow.appendChild(typDesc);
  box.appendChild(iconRow);

  var det=mkEl('div',{cls:'errdetail'});
  det.innerHTML='<strong>En este caso:</strong> '+esc(errorDetail);
  box.appendChild(det);
  sc.appendChild(box);
}

function showResult(c,ok,pts,bonus){
  var sc=gi('cscroll');sc.innerHTML='';

  // hero
  var rh=mkEl('div',{cls:'reshero fade'});
  rh.appendChild(mkEl('span',{cls:'resicon',txt:ok?'✅':'❌'}));
  var rt=mkEl('div',{cls:'restit',txt:ok?'¡Diagnóstico correcto!':'Diagnóstico incorrecto'});
  rt.style.color=ok?'var(--green)':'var(--red)';
  var rp=mkEl('div',{cls:'respts'});
  rp.textContent=ok?('+'+pts+' pts (100 base'+(bonus?' + '+bonus+' bonus':'')+')'):' 0 pts — revisa la explicación';
  rp.style.color=ok?'var(--green)':'var(--text3)';
  rh.appendChild(rt);rh.appendChild(rp);sc.appendChild(rh);

  // narrative
  var narr=mkEl('div',{cls:'narr',txt:ok?c.narr_ok:c.narr_fail});
  sc.appendChild(narr);
  if(!ok){
    var mech=c.mechanic==='order'?'order':'npc';
    buildErrorFeedback(sc,c,mech);
  }

  // explanation
  var exp=mkEl('div',{cls:'expcard'});
  exp.innerHTML='<strong>Explicación clínica:</strong><br><br>'+c.exp;
  sc.appendChild(exp);

  // npc review
  if(c.npcs){
    sc.appendChild(mkEl('div',{cls:'sec',txt:'Revisión de diagnósticos'}));
    c.npcs.forEach(function(n,i){
      var cls='npc '+(n.ok?'ok':(i===S.selNPC?'bad':'neu'));
      var nc=mkEl('div',{cls:cls});
      var hdr=mkEl('div',{cls:'npch'});
      var av=mkEl('div',{cls:'av'});av.style.background=n.bg;
      var avi=mkEl('i',{cls:'ti '+n.icon});avi.style.color=n.tc;av.appendChild(avi);
      var info=mkEl('div');
      var nm=mkEl('div',{cls:'nname',txt:n.n});
      if(n.ok){var b=mkEl('span',{cls:'badge b-ok',txt:'Correcto'});nm.appendChild(b);}
      info.appendChild(nm);
      info.appendChild(mkEl('div',{cls:'nrole',txt:n.r}));
      hdr.appendChild(av);hdr.appendChild(info);
      nc.appendChild(hdr);
      nc.appendChild(mkEl('div',{cls:'ndiag',txt:n.d}));
      sc.appendChild(nc);
    });
  }

  // order review
  if(c.mechanic==='order'){
    sc.appendChild(mkEl('div',{cls:'sec',style:'margin-top:14px;',txt:'Orden correcto'}));
    var oc=mkEl('div',{cls:'card',style:'padding:8px 14px;'});
    c.steps_correct.forEach(function(si,pos){
      var row=mkEl('div');row.style.cssText='display:flex;gap:10px;align-items:flex-start;padding:8px 0;border-bottom:1px solid rgba(0,194,255,.07);';
      var n=mkEl('div',{txt:String(pos+1)});n.style.cssText='font-family:var(--mono);font-size:12px;background:var(--green-bg);color:var(--green);border:1px solid var(--green-border);border-radius:5px;padding:2px 8px;flex-shrink:0;margin-top:2px;';
      var t=mkEl('div',{txt:c.steps[si]});t.style.cssText='font-size:13px;color:var(--text2);line-height:1.5;';
      row.appendChild(n);row.appendChild(t);oc.appendChild(row);
    });
    sc.appendChild(oc);
  }

  // next btn
  var div=mkEl('div');div.style.marginTop='16px';
  var btn=mkEl('button',{cls:'btn btn-p'});
  btn.innerHTML=S.ci<2?'<i class="ti ti-arrow-right"></i> Siguiente caso ('+(S.ci+2)+' de 3)':'<i class="ti ti-trophy"></i> Ver resultados finales';
  btn.onclick=function(){
    S.ci++;
    if(S.ci<CASOS.length)showRoleTransition(S.ci,function(){countdown(function(){loadCaso();});});
    else showFinal();
  };
  div.appendChild(btn);sc.appendChild(div);
  if(ok)setTimeout(confetti,300);
  sc.scrollTop=0;
}

// TIMER
function startTimer(){
  clearInterval(S.tiv);S.tstart=Date.now();
  var fill=gi('tfill'),num=gi('tnum');
  var sec=45;
  fill.style.width='100%';fill.className='tfill';num.className='tnum';num.textContent=sec;
  S.tiv=setInterval(function(){
    sec--;num.textContent=sec;fill.style.width=(sec/45*100)+'%';
    if(sec<=10){fill.classList.add('urg');num.classList.add('urg');}
    if(sec<=0)clearInterval(S.tiv);
  },1000);
}

// FINAL
function showFinal(){
  gi('role-bar').style.display='none';
  var total=S.scores.reduce(function(s,c){return s+c.pts;},0);
  gi('fmedal').textContent=total>=320?'🏆':total>=200?'🥈':'🎯';
  gi('fgrp').textContent='// '+S.grp.toUpperCase();
  gi('fscore').textContent=total;
  gi('fverdict').textContent=total>=320?'Diagnóstico de nivel experto. Razonamiento clínico sobresaliente.':total>=200?'Buen desempeño clínico. Revisen los casos fallados.':'El equipo puede mejorar. Usen las explicaciones como guía.';
  var dh='';
  S.scores.forEach(function(s,i){
    dh+='<div class="rrow"><span class="rpos" style="font-size:12px;width:auto;padding-right:8px;font-family:var(--mono);">C'+(i+1)+'</span><span class="rname" style="font-size:13px;">'+esc(s.titulo)+'</span><span class="rpts" style="color:'+(s.ok?'var(--green)':'var(--red)')+';">'+(s.ok?'✓':'✗')+' '+s.pts+'</span></div>';
  });
  gi('fdetalle').innerHTML=dh;
  var stored=getSt();
  var idx=-1;
  stored.forEach(function(g,i){if(g.name===S.grp)idx=i;});
  if(idx>=0)stored[idx].total=Math.max(stored[idx].total,total);
  else stored.push({name:S.grp,total:total});
  setSt(stored);
  var ranking=stored.sort(function(a,b){return b.total-a.total;});
  var medals=['🥇','🥈','🥉'];var rh='';
  ranking.forEach(function(g,i){
    var me=g.name===S.grp;
    rh+='<div class="rrow'+(me?' me':'')+'"><span class="rpos">'+(medals[i]||(i+1))+'</span><span class="rname">'+esc(g.name)+(me?' <span class="badge b-you">Tú</span>':'')+'</span><span class="rpts">'+g.total+' pts</span></div>';
  });
  gi('frank').innerHTML=rh;
  showScr('s-final');
  if(total>=320)setTimeout(confetti,400);
}

function goHome(){showScr('s-home');setMode('g');}

// CONFETTI
function confetti(){
  var cols=['#00C2FF','#00D68F','#FFB830','#FF6B8A','#4A9FE0','#00FFCC'];
  for(var i=0;i<60;i++){
    (function(i2){setTimeout(function(){
      var el=mkEl('div',{cls:'cp'});
      var w=5+Math.random()*7;
      el.style.cssText='left:'+Math.random()*100+'vw;top:-10px;background:'+cols[Math.floor(Math.random()*cols.length)]+';width:'+w+'px;height:'+w+'px;animation-duration:'+(2+Math.random()*2)+'s;border-radius:'+(Math.random()>.5?'50%':'2px')+';opacity:0.9;';
      document.body.appendChild(el);
      setTimeout(function(){el.remove();},4000);
    },i2*35);})(i);
  }
}
