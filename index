var S_ROLES = {clinico:'',esceptico:'',portavoz:''};

function buildRoleCards(){
  var el=gi('roles-cards');el.innerHTML='';
  ROLES_DEF.forEach(function(r){
    var card=mkEl('div',{cls:'card fade'});
    card.style.cssText='border-color:rgba(0,194,255,.2);margin-bottom:12px;';
    var top=mkEl('div');top.style.cssText='display:flex;align-items:center;gap:10px;margin-bottom:8px;';
    var em=mkEl('div',{txt:r.emoji});em.style.cssText='font-size:28px;line-height:1;';
    var info=mkEl('div');
    info.appendChild(mkEl('div',{txt:r.title,style:'font-family:var(--syne);font-size:15px;font-weight:700;color:var(--text);'}));
    top.appendChild(em);top.appendChild(info);
    card.appendChild(top);
    card.appendChild(mkEl('div',{txt:r.desc,style:'font-size:12px;color:var(--text2);line-height:1.6;padding:10px 12px;background:rgba(0,0,0,.2);border-radius:6px;border-left:2px solid rgba(0,194,255,.2);'}));
    el.appendChild(card);
  });
}

function startWithRoles(){
  var c=gi('r-clinico').value.trim();
  var e=gi('r-esceptico').value.trim();
  var p=gi('r-portavoz').value.trim();
  if(!c||!e||!p){
    if(!c)gi('r-clinico').focus();
    else if(!e)gi('r-esceptico').focus();
    else gi('r-portavoz').focus();
    return;
  }
  S_ROLES.clinico=c;S_ROLES.esceptico=e;S_ROLES.portavoz=p;
  countdown(function(){loadCaso();});
}

function getRoleForCaso(casoIdx){
  // rotate: caso 0→original, caso 1→shift1, caso 2→shift2
  var names=[S_ROLES.clinico,S_ROLES.esceptico,S_ROLES.portavoz];
  var shifted=[];
  for(var i=0;i<3;i++)shifted.push(names[(i+casoIdx)%3]);
  return {clinico:shifted[0],esceptico:shifted[1],portavoz:shifted[2]};
}

function showRoleBar(casoIdx){
  var bar=gi('role-bar');
  var inner=gi('role-bar-inner');
  var roles=getRoleForCaso(casoIdx);
  var rotLabels=['Turno original','Rotación 1','Rotación 2'];
  var items=[
    {emoji:'🗣',lbl:'Clínico',name:roles.clinico},
    {emoji:'🔍',lbl:'Escéptico',name:roles.esceptico},
    {emoji:'📝',lbl:'Portavoz',name:roles.portavoz}
  ];
  inner.innerHTML='';
  // rotation indicator
  if(casoIdx>0){
    var rotTag=mkEl('div');
    rotTag.style.cssText='display:flex;align-items:center;gap:5px;background:rgba(255,184,48,.1);border:1px solid rgba(255,184,48,.25);border-radius:6px;padding:5px 10px;white-space:nowrap;flex-shrink:0;';
    rotTag.innerHTML='<i class="ti ti-rotate-clockwise" style="font-size:13px;color:var(--amber);"></i><span style="font-family:var(--mono);font-size:9px;color:var(--amber);letter-spacing:.06em;">'+rotLabels[casoIdx]+'</span>';
