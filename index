    var sep=mkEl('div');sep.style.cssText='width:1px;background:rgba(0,194,255,.1);flex-shrink:0;margin:2px 0;';
    inner.appendChild(sep);
  }
  items.forEach(function(it){
    var chip=mkEl('div');
    chip.style.cssText='display:flex;align-items:center;gap:6px;background:var(--c2);border:1px solid rgba(0,194,255,.15);border-radius:6px;padding:5px 10px;white-space:nowrap;flex-shrink:0;';
