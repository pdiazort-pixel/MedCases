  {key:'clinico', emoji:'🗣', title:'El Clínico', desc:'Lee el caso en voz alta y propone el diagnóstico inicial.'},
  {key:'esceptico', emoji:'🔍', title:'El Escéptico', desc:'Debe argumentar contra la primera propuesta antes de decidir.'},
