<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1"/>
<title>MedCases</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.0.0/tabler-icons.min.css"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --c0:#060A0F;
  --c1:#0D1520;
  --c2:#112240;
  --c3:#1A3460;
  --accent:#00C2FF;
  --accent2:#0090CC;
  --accent-dim:rgba(0,194,255,.12);
  --accent-glow:rgba(0,194,255,.25);
  --green:#00D68F;--green-bg:rgba(0,214,143,.1);--green-border:rgba(0,214,143,.4);
  --red:#FF4757;--red-bg:rgba(255,71,87,.1);--red-border:rgba(255,71,87,.4);
  --amber:#FFB830;--amber-bg:rgba(255,184,48,.1);
  --paper:#F0F4F8;--paper2:#E2EAF0;--paper3:#C8D8E8;
  --text:#E8F0F8;--text2:#8FA8C0;--text3:#506070;
  --syne:'Syne',sans-serif;
  --inter:'Inter',sans-serif;
  --mono:'JetBrains Mono',monospace;
  --r:8px;--r-lg:14px;--r-xl:20px;
}
html,body{height:100%;}
body{font-family:var(--inter);background:var(--c0);color:var(--text);min-height:100vh;display:flex;justify-content:center;overflow-x:hidden;}
.app{width:100%;max-width:480px;background:var(--c1);min-height:100vh;display:flex;flex-direction:column;position:relative;}

/* SCANLINE effect */
.app::before{content:'';position:fixed;top:0;left:50%;transform:translateX(-50%);width:480px;max-width:100%;height:100%;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.03) 2px,rgba(0,0,0,.03) 4px);pointer-events:none;z-index:1000;}

/* HEADER */
.hdr{background:var(--c0);border-bottom:1px solid rgba(0,194,255,.15);padding:12px 16px;display:flex;align-items:center;gap:10px;position:sticky;top:0;z-index:50;flex-shrink:0;}
.hdr-dot{width:6px;height:6px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--accent);animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.3;}}
.hdr-txt{font-family:var(--mono);font-size:10px;color:var(--text2);letter-spacing:.1em;}
.hdr-right{margin-left:auto;font-family:var(--mono);font-size:10px;color:var(--text3);}

/* SCREENS */
.screen{display:none;flex:1;flex-direction:column;}
.screen.active{display:flex;}
.scroll{flex:1;overflow-y:auto;padding:20px 16px 100px;}
.scroll::-webkit-scrollbar{width:3px;}
.scroll::-webkit-scrollbar-track{background:transparent;}
.scroll::-webkit-scrollbar-thumb{background:var(--c3);border-radius:2px;}

/* ── HOME ── */
.hero{background:var(--c0);padding:0;position:relative;overflow:hidden;}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 70% 30%,rgba(0,144,204,.18) 0%,transparent 70%),radial-gradient(ellipse 50% 40% at 20% 80%,rgba(0,194,255,.08) 0%,transparent 60%);pointer-events:none;}
.hero-inner{position:relative;padding:32px 20px 28px;}
.hero-tag{font-family:var(--mono);font-size:9px;color:var(--accent);letter-spacing:.15em;margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.hero-tag::before{content:'';width:20px;height:1px;background:var(--accent);}
.hero-hook{font-family:var(--syne);font-size:13px;color:var(--text2);line-height:1.6;margin-bottom:18px;font-style:italic;padding-left:12px;border-left:2px solid var(--accent-dim);}
.hero-title{font-family:var(--syne);font-size:32px;font-weight:800;line-height:1.1;color:var(--text);margin-bottom:4px;}
.hero-title em{color:var(--accent);font-style:normal;text-shadow:0 0 30px rgba(0,194,255,.4);}
.hero-sub{font-size:12px;color:var(--text3);margin-top:8px;font-family:var(--mono);letter-spacing:.03em;}
.hero-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(0,194,255,.1);border:1px solid rgba(0,194,255,.1);border-radius:var(--r-lg);overflow:hidden;margin-top:22px;}
.hs{background:var(--c1);text-align:center;padding:14px 8px;}
.hs-n{font-family:var(--syne);font-size:22px;font-weight:800;color:var(--accent);}
.hs-l{font-family:var(--mono);font-size:8px;color:var(--text3);letter-spacing:.08em;margin-top:4px;}

/* TABS */
.tabs{display:flex;border-bottom:1px solid rgba(0,194,255,.1);background:var(--c0);flex-shrink:0;}
.tab{flex:1;padding:13px 8px;text-align:center;font-size:12px;font-weight:600;color:var(--text3);cursor:pointer;border:none;background:transparent;font-family:var(--inter);border-bottom:2px solid transparent;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:6px;letter-spacing:.02em;}
.tab i{font-size:15px;}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);}

/* INPUTS */
.flbl{font-family:var(--mono);font-size:10px;font-weight:700;color:var(--text3);letter-spacing:.08em;margin-bottom:8px;display:block;}
.finp{width:100%;padding:13px 16px;border:1px solid rgba(0,194,255,.2);border-radius:var(--r);font-size:15px;font-weight:600;font-family:var(--inter);color:var(--text);background:var(--c2);outline:none;transition:border-color .2s,box-shadow .2s;}
.finp:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-dim);}
.finp::placeholder{color:var(--text3);}
.fg{margin-bottom:18px;}

/* BUTTONS */
.btn{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:14px;border-radius:var(--r);border:none;font-size:14px;font-weight:700;font-family:var(--inter);cursor:pointer;transition:all .15s;margin-bottom:10px;letter-spacing:.02em;}
.btn i{font-size:18px;}
.btn-p{background:var(--accent);color:var(--c0);}
.btn-p:hover{background:var(--accent2);box-shadow:0 0 20px var(--accent-glow);}
.btn-g{background:transparent;color:var(--text2);border:1px solid rgba(0,194,255,.2);}
.btn-g:hover{background:var(--accent-dim);border-color:rgba(0,194,255,.4);}
.btn-d{background:transparent;color:var(--red);border:1px solid var(--red-border);}
.btn-d:hover{background:var(--red-bg);}
.btn:disabled{opacity:.25;cursor:not-allowed;}

/* INFO */
.info{background:var(--c2);border:1px solid rgba(0,194,255,.1);border-radius:var(--r-lg);padding:14px 16px;font-size:12px;color:var(--text2);line-height:1.7;}
.info strong{color:var(--text);}

/* CARD */
.card{background:var(--c2);border:1px solid rgba(0,194,255,.12);border-radius:var(--r-lg);padding:16px;margin-bottom:14px;}
.sec{font-family:var(--mono);font-size:9px;font-weight:700;letter-spacing:.12em;color:var(--text3);text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.sec::after{content:'';flex:1;height:1px;background:rgba(0,194,255,.1);}

/* COMPLEXITY BAR */
.complexity{margin-bottom:16px;}
.complexity-lbl{font-family:var(--mono);font-size:9px;color:var(--text3);letter-spacing:.08em;margin-bottom:6px;display:flex;justify-content:space-between;}
.complexity-track{height:6px;background:var(--c3);border-radius:3px;overflow:hidden;}
.complexity-fill{height:100%;border-radius:3px;transition:width .8s cubic-bezier(.4,0,.2,1);}
.cx-1{background:linear-gradient(90deg,var(--green),var(--green));width:33%;}
.cx-2{background:linear-gradient(90deg,var(--green),var(--amber));width:66%;}
.cx-3{background:linear-gradient(90deg,var(--amber),var(--red));width:100%;}
.cx-tag{font-family:var(--mono);font-size:9px;padding:2px 8px;border-radius:3px;font-weight:700;}
.cx-tag-1{background:var(--green-bg);color:var(--green);}
.cx-tag-2{background:var(--amber-bg);color:var(--amber);}
.cx-tag-3{background:var(--red-bg);color:var(--red);}

/* COUNTDOWN */
.cdov{position:fixed;inset:0;background:rgba(6,10,15,.95);display:flex;align-items:center;justify-content:center;z-index:200;flex-direction:column;gap:10px;backdrop-filter:blur(8px);}
.cdn{font-family:var(--syne);font-size:120px;font-weight:800;color:var(--accent);line-height:1;text-shadow:0 0 60px rgba(0,194,255,.5);animation:pop .4s ease;}
@keyframes pop{0%{transform:scale(1.5);opacity:0;}100%{transform:scale(1);opacity:1;}}
.cdl{font-family:var(--mono);font-size:12px;color:var(--text2);letter-spacing:.15em;}

/* PIN */
.overlay{position:fixed;inset:0;background:rgba(6,10,15,.85);display:flex;align-items:center;justify-content:center;z-index:100;padding:20px;backdrop-filter:blur(10px);}
.pinbox{background:var(--c1);border:1px solid rgba(0,194,255,.2);border-radius:var(--r-xl);padding:30px 24px;width:100%;max-width:320px;box-shadow:0 0 60px rgba(0,0,0,.5);}
.pin-dots{display:flex;justify-content:center;gap:16px;margin:16px 0;}
.pin-dot{width:14px;height:14px;border-radius:50%;background:var(--c3);border:1px solid rgba(0,194,255,.2);transition:all .2s;}
.pin-dot.on{background:var(--accent);box-shadow:0 0 10px var(--accent-glow);border-color:var(--accent);}
.numpad{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:12px;}
.nkey{padding:16px;border-radius:var(--r);border:1px solid rgba(0,194,255,.15);font-size:20px;font-weight:700;font-family:var(--mono);background:var(--c2);cursor:pointer;text-align:center;color:var(--text);transition:all .1s;}
.nkey:hover{background:var(--c3);border-color:rgba(0,194,255,.3);}
.nkey:active{transform:scale(.92);}
.pin-err{font-family:var(--mono);font-size:12px;color:var(--red);text-align:center;margin-top:10px;min-height:20px;}

/* TIMER */
.topbar{padding:14px 16px 0;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.cbadge{font-family:var(--mono);font-size:10px;padding:4px 10px;border-radius:4px;background:var(--accent-dim);color:var(--accent);border:1px solid rgba(0,194,255,.25);letter-spacing:.06em;}
.twrap{display:flex;align-items:center;gap:6px;}
.tnum{font-family:var(--mono);font-size:18px;font-weight:700;color:var(--text);transition:color .3s;}
.tnum.urg{color:var(--red);text-shadow:0 0 10px rgba(255,71,87,.4);}
.tbar{height:3px;background:var(--c3);margin:12px 16px 0;border-radius:2px;overflow:hidden;flex-shrink:0;}
.tfill{height:100%;border-radius:2px;background:var(--accent);transition:width 1s linear,background .5s;box-shadow:0 0 8px rgba(0,194,255,.4);}
.tfill.urg{background:var(--red);box-shadow:0 0 8px rgba(255,71,87,.4);}
.pdots{display:flex;gap:8px;justify-content:center;padding:12px 0 4px;flex-shrink:0;}
.dot{width:8px;height:8px;border-radius:50%;background:var(--c3);}
.dot.done{background:var(--green);box-shadow:0 0 6px rgba(0,214,143,.4);}
.dot.active{background:var(--accent);box-shadow:0 0 6px var(--accent-glow);}

/* CASO CARD */
.ccard{background:var(--c0);border:1px solid rgba(0,194,255,.15);border-radius:var(--r-xl);padding:20px;margin-bottom:14px;position:relative;overflow:hidden;}
.ccard::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--accent),transparent);}
.cnum{font-family:var(--mono);font-size:9px;color:var(--accent);letter-spacing:.15em;margin-bottom:10px;opacity:.7;}
.ctit{font-family:var(--syne);font-size:20px;font-weight:700;color:var(--text);margin-bottom:16px;line-height:1.2;}
.dato{display:flex;gap:12px;margin-bottom:10px;align-items:flex-start;}
.dato i{font-size:15px;color:var(--accent2);flex-shrink:0;margin-top:2px;opacity:.8;}
.dato span{font-size:13px;color:var(--text2);line-height:1.6;}
.mech-tag{font-family:var(--mono);font-size:10px;color:var(--accent);background:var(--accent-dim);border:1px solid rgba(0,194,255,.2);padding:6px 12px;border-radius:6px;display:inline-block;margin-bottom:16px;letter-spacing:.04em;}

/* NPC CARDS */
.npc{border:1px solid rgba(0,194,255,.15);border-radius:var(--r-lg);padding:16px;margin-bottom:10px;cursor:pointer;transition:all .2s;background:var(--c2);}
.npc:hover{border-color:rgba(0,194,255,.4);background:var(--c3);transform:translateY(-2px);}
.npc.sel{border-color:var(--accent);background:rgba(0,194,255,.08);box-shadow:0 0 0 1px var(--accent),0 4px 20px rgba(0,194,255,.1);}
.npc.ok{border-color:var(--green);background:var(--green-bg);cursor:default;transform:none;box-shadow:0 0 20px rgba(0,214,143,.1);}
.npc.bad{border-color:var(--red);background:var(--red-bg);opacity:.6;cursor:default;transform:none;}
.npc.neu{cursor:default;transform:none;}
.npch{display:flex;gap:12px;align-items:center;margin-bottom:10px;}
.av{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;}
.av::after{content:'';position:absolute;inset:0;border-radius:12px;border:1px solid rgba(255,255,255,.1);}
.av i{font-size:22px;}
.nname{font-size:14px;font-weight:700;color:var(--text);font-family:var(--inter);}
.nrole{font-size:11px;color:var(--text3);margin-top:2px;}
.npersona{font-size:11px;color:var(--text3);font-style:italic;margin-bottom:10px;padding:8px 12px;background:rgba(0,0,0,.2);border-radius:6px;border-left:2px solid rgba(0,194,255,.2);line-height:1.5;}
.ndiag{font-size:14px;font-weight:700;color:var(--text);margin-bottom:6px;}
.narg{font-size:12px;color:var(--text2);line-height:1.65;}

/* JUSTIFICATION BOX */
.just-wrap{background:var(--c0);border:1px solid rgba(255,184,48,.25);border-radius:var(--r-lg);padding:16px;margin:14px 0;}
.just-label{font-family:var(--mono);font-size:10px;color:var(--amber);letter-spacing:.08em;margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.just-label i{font-size:14px;}
.just-sub{font-size:12px;color:var(--text3);margin-bottom:10px;line-height:1.5;}
.just-ta{width:100%;background:var(--c2);border:1px solid rgba(255,184,48,.2);border-radius:var(--r);padding:12px 14px;font-size:13px;font-family:var(--inter);color:var(--text);resize:none;outline:none;min-height:80px;line-height:1.6;transition:border-color .2s;}
.just-ta:focus{border-color:var(--amber);box-shadow:0 0 0 3px rgba(255,184,48,.1);}
.just-ta::placeholder{color:var(--text3);}

/* ORDER */
.oitem{border:1px solid rgba(0,194,255,.15);border-radius:var(--r);padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px;background:var(--c2);cursor:pointer;transition:all .15s;}
.oitem:hover{border-color:rgba(0,194,255,.35);background:var(--c3);}
.oitem.osel{border-color:var(--accent);background:rgba(0,194,255,.08);}
.onum{font-family:var(--mono);font-size:13px;font-weight:700;width:28px;height:28px;border-radius:6px;background:var(--c3);border:1px solid rgba(0,194,255,.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--accent);transition:all .2s;}
.oitem.osel .onum{background:var(--accent);color:var(--c0);border-color:var(--accent);}
.otxt{font-size:13px;color:var(--text2);line-height:1.45;flex:1;}

/* REVEAL */
.revcard{border:1px solid rgba(0,194,255,.12);border-radius:var(--r-lg);overflow:hidden;margin-bottom:10px;background:var(--c2);}
.revhdr{padding:14px 16px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;transition:background .15s;}
.revhdr:hover{background:var(--c3);}
.revhdr-lbl{font-size:13px;font-weight:600;color:var(--text);}
.revbody{padding:0 16px;max-height:0;overflow:hidden;transition:max-height .35s ease,padding .3s;}
.revbody.open{max-height:400px;padding:14px 16px;}
.clue{font-family:var(--mono);font-size:9px;background:var(--accent-dim);color:var(--accent);border:1px solid rgba(0,194,255,.2);padding:3px 8px;border-radius:4px;letter-spacing:.06em;}
.clue.revealed{background:rgba(0,214,143,.1);color:var(--green);border-color:rgba(0,214,143,.3);}

/* RESULT */
.reshero{text-align:center;padding:24px 0 16px;position:relative;}
.resicon{font-size:56px;line-height:1;display:block;margin-bottom:10px;}
.restit{font-family:var(--syne);font-size:24px;font-weight:800;margin-bottom:6px;}
.respts{font-family:var(--mono);font-size:13px;}
.narr{background:var(--c0);border:1px solid rgba(0,194,255,.12);border-radius:var(--r-lg);padding:16px 18px;font-size:13px;line-height:1.75;margin-bottom:14px;color:var(--text2);font-style:italic;position:relative;}
.narr::before{content:'//';font-family:var(--mono);font-size:11px;color:var(--accent);opacity:.5;display:block;margin-bottom:6px;}
.expcard{background:var(--c2);border-left:2px solid var(--accent);border-radius:0 var(--r-lg) var(--r-lg) 0;padding:16px 18px;font-size:13px;color:var(--text2);line-height:1.75;margin-bottom:14px;}
.expcard strong{color:var(--text);}

/* JUST DISPLAY (docente) */
.just-disp{background:rgba(255,184,48,.06);border:1px solid rgba(255,184,48,.2);border-radius:var(--r);padding:10px 12px;font-size:12px;color:var(--text2);line-height:1.6;margin-top:6px;font-style:italic;}
.just-grp{font-family:var(--mono);font-size:10px;color:var(--amber);margin-bottom:4px;}

/* BADGE */
.badge{display:inline-flex;align-items:center;gap:3px;font-family:var(--mono);font-size:9px;font-weight:700;padding:3px 8px;border-radius:4px;letter-spacing:.04em;}
.b-ok{background:var(--green-bg);color:var(--green);border:1px solid var(--green-border);}
.b-you{background:var(--accent-dim);color:var(--accent);border:1px solid rgba(0,194,255,.3);}

/* RANK */
.rrow{display:flex;align-items:center;gap:10px;padding:11px 0;border-bottom:1px solid rgba(0,194,255,.07);}
.rrow:last-child{border-bottom:none;}
.rrow.me{background:var(--accent-dim);border-radius:var(--r);padding:11px 12px;margin:2px -12px;border:1px solid rgba(0,194,255,.2);}
.rpos{font-family:var(--mono);font-size:15px;width:28px;text-align:center;color:var(--text3);flex-shrink:0;}
.rname{flex:1;font-size:14px;font-weight:600;color:var(--text);}
.rpts{font-family:var(--mono);font-size:14px;font-weight:700;color:var(--accent);}

/* FINAL */
.finalhero{background:var(--c0);padding:36px 20px 30px;text-align:center;position:relative;overflow:hidden;}
.finalhero::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(0,194,255,.08) 0%,transparent 70%);pointer-events:none;}
.fmedal{font-size:56px;display:block;margin-bottom:14px;filter:drop-shadow(0 0 20px rgba(255,184,48,.4));}
.fgrp{font-family:var(--mono);font-size:10px;color:var(--text3);letter-spacing:.12em;margin-bottom:10px;}
.fscore{font-family:var(--syne);font-size:72px;font-weight:800;color:var(--accent);line-height:1;text-shadow:0 0 40px rgba(0,194,255,.3);}
.fpts{font-family:var(--mono);font-size:10px;color:var(--text3);margin-top:6px;letter-spacing:.1em;}
.fverdict{font-size:14px;color:var(--text2);margin-top:14px;line-height:1.6;max-width:280px;margin-left:auto;margin-right:auto;}

/* DOCENTE */
.dhdr{background:var(--c0);border:1px solid rgba(0,194,255,.15);border-radius:var(--r-xl);padding:18px;margin-bottom:16px;position:relative;overflow:hidden;}
.dhdr::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--accent),transparent);}
.dhtit{font-family:var(--syne);font-size:16px;font-weight:700;color:var(--text);display:flex;align-items:center;gap:8px;margin-bottom:4px;}
.dhsub{font-family:var(--mono);font-size:10px;color:var(--text3);letter-spacing:.04em;}
.arow{display:flex;align-items:flex-start;gap:10px;padding:10px 0;border-bottom:1px solid rgba(0,194,255,.07);}
.arow:last-child{border-bottom:none;}
.anum{font-family:var(--mono);font-size:10px;background:var(--accent-dim);color:var(--accent);border:1px solid rgba(0,194,255,.2);border-radius:4px;padding:2px 8px;flex-shrink:0;margin-top:2px;}
.atxt{font-size:13px;color:var(--text2);line-height:1.5;}
.atxt strong{color:var(--text);}

/* CONFETTI */
.cp{position:fixed;border-radius:2px;animation:fall linear forwards;pointer-events:none;z-index:500;}
@keyframes fall{0%{transform:translateY(-20px) rotate(0deg);opacity:1;}100%{transform:translateY(110vh) rotate(720deg);opacity:0;}}

/* FADE */
.fade{animation:fin .35s ease;}
@keyframes fin{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}

/* ERROR FEEDBACK */
.errbox{background:var(--red-bg);border:1px solid var(--red-border);border-radius:var(--r-lg);padding:16px 18px;margin-bottom:14px;position:relative;overflow:hidden;}
.errbox::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--red),transparent);}
.errtype{font-family:var(--mono);font-size:10px;letter-spacing:.1em;margin-bottom:8px;display:flex;align-items:center;gap:8px;}
.errtype-badge{padding:3px 10px;border-radius:4px;font-weight:700;font-size:10px;}
.errtype-omision{background:rgba(255,71,87,.2);color:#FF8C96;border:1px solid rgba(255,71,87,.3);}
.errtype-frecuencia{background:rgba(255,184,48,.15);color:var(--amber);border:1px solid rgba(255,184,48,.3);}
.errtype-anclaje{background:rgba(180,80,255,.15);color:#C880FF;border:1px solid rgba(180,80,255,.3);}
.errtype-extrapolacion{background:rgba(0,214,143,.1);color:var(--green);border:1px solid rgba(0,214,143,.3);}
.errdetail{font-size:13px;color:var(--text2);line-height:1.7;}
.errdetail strong{color:var(--text);}

/* DIVIDER */
.divider{height:1px;background:rgba(0,194,255,.08);margin:16px 0;}

textarea{font-family:var(--inter);}
</style>
</head>
